# Mistral AI API key (required for story generation)
MISTRAL_API_KEY=

# OpenAI API key (optional, needed for DALL-E scene images)
# OPENAI_API_KEY=

# SQLite database path (optional — omit to disable story saving in deployed environments)
# DATABASE_URL="file:./dev.db"

# Rate limiting (optional, defaults below)
# RATE_LIMIT_MAX=30
# RATE_LIMIT_WINDOW_MS=60000

# Daily token budget (optional)
# MAX_DAILY_TOKENS=1000000
